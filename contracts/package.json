{
  "name": "cryptowordplay-contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile":          "hardhat compile",
    "test":             "hardhat test",
    "test:gas":         "REPORT_GAS=true hardhat test",
    "deploy:testnet":   "hardhat run scripts/deploy.js --network base-sepolia",
    "deploy:mainnet":   "hardhat run scripts/deploy.js --network base",
    "deploy:local":     "hardhat run scripts/deploy.js --network localhost",
    "verify:testnet":   "hardhat verify --network base-sepolia",
    "verify:mainnet":   "hardhat verify --network base",
    "node":             "hardhat node",
    "clean":            "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0",
    "dotenv": "^16.3.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}
