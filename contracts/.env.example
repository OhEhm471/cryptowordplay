# ============================================================
# Crypto Wordplay — Contracts Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# Deployer wallet private key (needs ETH on Base for gas)
# Generate a dedicated deployer wallet — never use your main wallet
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key_here

# Basescan API key for contract verification
# Get from https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key

# Backend signer wallet PUBLIC address
# This is the address whose private key (BADGE_SIGNER_PRIVATE_KEY in backend/.env)
# will sign mint vouchers. Must be set before deployment.
BADGE_SIGNER_ADDRESS=0x_your_backend_signer_public_address

# Badge metadata base URI (trailing slash required)
BADGE_BASE_URI=https://cryptowordplay.xyz/api/badges/metadata/

# Contract-level metadata URI (OpenSea collection info)
BADGE_CONTRACT_URI=https://cryptowordplay.xyz/api/badges/contract
