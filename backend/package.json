{
  "name": "cryptowordplay-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "migrate:rollback": "node src/db/migrate_all.js rollback",
    "migrate:s3": "node src/db/migrations_s3.js",
    "migrate:s4": "node src/db/migrations_s4.js",
    "migrate:s4c": "node src/db/migrations_s4c.js",
    "migrate:s4d": "node src/db/migrations_s4d.js",
    "migrate:all": "node src/db/migrate_all.js",
    "migrate:status": "node src/db/migrate_all.js status",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=unit",
    "test:integration": "jest --runInBand --testPathPattern=integration --testPathIgnorePatterns=mock",
    "test:ci": "jest --runInBand --forceExit",
    "test:mock": "jest --runInBand --testPathPattern=mock"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "winston": "^3.11.0",
    "viem": "^2.7.0",
    "date-fns": "^3.3.1",
    "uuid": "^9.0.0",
    "@napi-rs/canvas": "^0.1.44",
    "node-cron": "^3.0.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "globalSetup": "./src/__tests__/globalSetup.js",
    "globalTeardown": "./src/__tests__/globalTeardown.js",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/db/migrate*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    },
    "testTimeout": 30000
  }
}
